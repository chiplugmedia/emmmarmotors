RewriteEngine On

# =========================
# FORCE HTTPS (MUST BE FIRST)
# =========================
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]


# =========================
# EXCLUDE dsociopay FROM ALL REWRITES
# (IMPORTANT - PREVENT CONFLICTS)
# =========================
RewriteRule ^dsociopay\.php$ - [L]
RewriteRule ^dsociopay/?$ dsociopay.php [L,QSA]


# =========================
# PRODUCT ROUTE
# =========================
RewriteRule ^dash/product/([0-9a-zA-Z_-]+)$ dash/product.php?identifier=$1 [L,QSA]


# =========================
# REMOVE .PHP EXTENSION (SAFE VERSION)
# =========================
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteCond %{REQUEST_URI} !^/dsociopay/?$
RewriteRule ^([^\.]+)$ $1.php [L]


# =========================
# CLEAN URL REDIRECT (.php → no .php)
# EXCLUDE dsociopay.php
# =========================
RewriteCond %{THE_REQUEST} \.php [NC]
RewriteCond %{REQUEST_URI} !^/dsociopay\.php$
RewriteRule ^(.+)\.php$ /$1 [R=301,L]

# BEGIN cPanel-generated php ini directives, do not edit
# Manual editing of this file may result in unexpected behavior.
# To make changes to this file, use the cPanel MultiPHP INI Editor (Home >> Software >> MultiPHP INI Editor)
# For more information, read our documentation (https://go.cpanel.net/EA4ModifyINI)
<IfModule php8_module>
   php_flag display_errors Off
   php_value max_execution_time 30
   php_value max_input_time 60
   php_value max_input_vars 1000
   php_value memory_limit 32M
   php_value post_max_size 32M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/var/cpanel/php/sessions/ea-php80"
   php_value upload_max_filesize 32M
   php_flag zlib.output_compression Off
</IfModule>
<IfModule lsapi_module>
   php_flag display_errors Off
   php_value max_execution_time 30
   php_value max_input_time 60
   php_value max_input_vars 1000
   php_value memory_limit 32M
   php_value post_max_size 32M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/var/cpanel/php/sessions/ea-php80"
   php_value upload_max_filesize 32M
   php_flag zlib.output_compression Off
</IfModule>
# END cPanel-generated php ini directives, do not edit

